generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PartnerType {
  SUPPLIER
  CUSTOMER
  BOTH
}

enum OrderStatus {
  DRAFT
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum MovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
}

model Role {
  id          String @id @default(uuid())
  name        String @unique
  description String?
  users       User[]

  @@map("roles")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String
  name         String
  roleId       String         @map("role_id")
  role         Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Product {
  id                 String              @id @default(uuid())
  sku                String              @unique
  name               String
  description        String?             @db.Text
  imageUrl           String?             @map("image_url")
  unit               String              @default("EA")
  price              Decimal             @default(0) @db.Decimal(12, 2)
  isActive           Boolean             @default(true) @map("is_active")
  inventoryItems     Inventory[]
  inventoryMovements InventoryMovement[]
  inboundItems       InboundItem[]
  outboundItems      OutboundItem[]
  purchaseOrderItems PurchaseOrderItem[]
  shopMappings       ShopProductMapping[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([name])
  @@map("products")
}

model Warehouse {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  address   String?
  isActive  Boolean    @default(true) @map("is_active")
  locations Location[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("warehouses")
}

model Location {
  id                 String              @id @default(uuid())
  warehouseId        String              @map("warehouse_id")
  code               String
  name               String?
  warehouse          Warehouse           @relation(fields: [warehouseId], references: [id])
  inventoryItems     Inventory[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@map("locations")
}

model Inventory {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  locationId String   @map("location_id")
  quantity   Int      @default(0)
  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
  @@map("inventory")
}

model InventoryMovement {
  id            String        @id @default(uuid())
  productId     String        @map("product_id")
  locationId    String?       @map("location_id")
  type          MovementType
  quantity      Int
  beforeQty     Int?          @map("before_qty")
  afterQty      Int?          @map("after_qty")
  referenceType String?       @map("reference_type")
  referenceId   String?       @map("reference_id")
  note          String?
  createdById   String?       @map("created_by_id")
  product       Product       @relation(fields: [productId], references: [id])
  location      Location?     @relation(fields: [locationId], references: [id])
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([productId])
  @@index([locationId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Partner {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  type           PartnerType     @default(SUPPLIER)
  contactName    String?         @map("contact_name")
  phone          String?
  email          String?
  address        String?
  isActive       Boolean         @default(true) @map("is_active")
  purchaseOrders PurchaseOrder[]
  inboundOrders  InboundOrder[]
  outboundOrders OutboundOrder[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([name])
  @@map("partners")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNo     String              @unique @map("order_no")
  partnerId   String              @map("partner_id")
  status      OrderStatus         @default(DRAFT)
  note        String?
  requestedAt DateTime            @default(now()) @map("requested_at")
  approvedAt  DateTime?           @map("approved_at")
  completedAt DateTime?           @map("completed_at")
  partner     Partner             @relation(fields: [partnerId], references: [id])
  items       PurchaseOrderItem[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([partnerId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  productId       String        @map("product_id")
  quantity        Int
  unitPrice       Decimal       @default(0) @map("unit_price") @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model InboundOrder {
  id          String        @id @default(uuid())
  orderNo     String        @unique @map("order_no")
  partnerId   String?       @map("partner_id")
  status      OrderStatus   @default(DRAFT)
  note        String?
  requestedAt DateTime      @default(now()) @map("requested_at")
  approvedAt  DateTime?     @map("approved_at")
  completedAt DateTime?     @map("completed_at")
  partner     Partner?      @relation(fields: [partnerId], references: [id])
  items       InboundItem[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([partnerId])
  @@index([status])
  @@map("inbound_orders")
}

model InboundItem {
  id             String       @id @default(uuid())
  inboundOrderId String       @map("inbound_order_id")
  productId      String       @map("product_id")
  quantity       Int
  locationId     String?      @map("location_id")
  inboundOrder   InboundOrder @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id])

  @@index([inboundOrderId])
  @@index([productId])
  @@map("inbound_items")
}

model OutboundOrder {
  id          String         @id @default(uuid())
  orderNo     String         @unique @map("order_no")
  partnerId   String?        @map("partner_id")
  status      OrderStatus    @default(DRAFT)
  note        String?
  requestedAt DateTime       @default(now()) @map("requested_at")
  approvedAt  DateTime?      @map("approved_at")
  completedAt DateTime?      @map("completed_at")
  partner        Partner?        @relation(fields: [partnerId], references: [id])
  items          OutboundItem[]
  shopOrderSync  ShopOrderSync?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([partnerId])
  @@index([status])
  @@map("outbound_orders")
}

model ShopProductMapping {
  id            String    @id @default(uuid())
  shopProductId Int       @map("shop_product_id")
  shopSku       String?   @map("shop_sku")
  shopName      String?   @map("shop_name")
  productId     String    @map("product_id")
  product       Product   @relation(fields: [productId], references: [id])
  lastStockPush DateTime? @map("last_stock_push")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([shopProductId])
  @@index([productId])
  @@map("shop_product_mappings")
}

model ShopOrderSync {
  id              String         @id @default(uuid())
  shopOrderId     Int            @unique @map("shop_order_id")
  outboundOrderId String?        @unique @map("outbound_order_id")
  outboundOrder   OutboundOrder? @relation(fields: [outboundOrderId], references: [id])
  shopStatus      String?        @map("shop_status")
  syncedAt        DateTime       @default(now()) @map("synced_at")
  fulfilledAt     DateTime?      @map("fulfilled_at")
  errorMessage    String?        @map("error_message") @db.Text

  @@map("shop_order_syncs")
}

model OutboundItem {
  id              String        @id @default(uuid())
  outboundOrderId String        @map("outbound_order_id")
  productId       String        @map("product_id")
  quantity        Int
  locationId      String?       @map("location_id")
  outboundOrder   OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([outboundOrderId])
  @@index([productId])
  @@map("outbound_items")
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  isPinned  Boolean  @default(false) @map("is_pinned")
  authorId  String?  @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("notices")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt])
  @@unique([userId, type])
  @@map("notifications")
}
